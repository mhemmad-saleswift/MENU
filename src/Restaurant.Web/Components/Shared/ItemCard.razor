@inject LanguageState Lang

<a class="item-card reveal" href="/item/@Item.Slug">
    <div class="item-media @(string.IsNullOrEmpty(Item.PrimaryImage) ? "placeholder" : "")">
        @if (!string.IsNullOrEmpty(Item.PrimaryImage))
        {
            <img src="@Item.PrimaryImage" alt="@t.Name" loading="lazy" />
        }
        else
        {
            <span>🍽️</span>
        }

        <div class="item-badges">
            @if (Item.IsRecommended)
            {
                <span class="badge badge-rec">★ @Lang["badge.recommended"]</span>
            }
            @if (Item.IsPopular)
            {
                <span class="badge badge-popular">🔥 @Lang["badge.popular"]</span>
            }
        </div>

        @if (Item.HasAr)
        {
            <span class="ar-pill">📦 AR</span>
        }

        @if (!Item.IsAvailable)
        {
            <div class="unavailable-veil"><span>@Lang["item.unavailable"]</span></div>
        }
    </div>

    <div class="item-body">
        <h3>@t.Name</h3>
        @if (!string.IsNullOrWhiteSpace(t.Description))
        {
            <p class="item-desc">@t.Description</p>
        }

        <div class="dietary-row">
            @foreach (var (label, css) in Display.Tags(Item.DietaryTags, Lang.Current))
            {
                <span class="tag @css">@label</span>
            }
        </div>

        <div class="item-foot">
            <span class="price">@Item.Price.ToString("0.##")@Item.Currency</span>
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public MenuItem Item { get; set; } = default!;
    MenuItemTranslation t => Item.T(Lang.Current);
}
