@page "/menu"
@inject IMenuService MenuSvc
@inject LanguageState Lang

<PageTitle>@Lang["menu.title"] — @Lang["brand"]</PageTitle>

<section class="section menu-section">
    <div class="container">
        <div class="section-head reveal">
            <div class="eyebrow">@Lang["brand"]</div>
            <h1>@Lang["menu.title"]</h1>
            <p>@Lang["home.categories"]</p>
        </div>

        <div class="cat-cards">
            @foreach (var c in categoriesWithItems)
            {
                <a class="cat-card-link reveal" href="/menu/@c.Slug">
                    <div class="cat-card-img" style="@(CatImage(c) is { } img ? $"background-image:url('{img}')" : "")">
                        @if (CatImage(c) is null)
                        {
                            <span class="cat-card-emoji">@c.Icon</span>
                        }
                    </div>
                    <span class="cat-card-name">@c.Icon @c.T(Lang.Current).Name</span>
                </a>
            }
        </div>
    </div>
</section>

@code {
    List<Category> categories = [];
    List<MenuItem> allItems = [];
    readonly Dictionary<Guid, string?> catImages = new();

    List<Category> categoriesWithItems => categories.Where(c => allItems.Any(i => i.CategoryId == c.Id)).ToList();
    string? CatImage(Category c) => catImages.GetValueOrDefault(c.Id);

    protected override async Task OnInitializedAsync()
    {
        categories = await MenuSvc.GetCategoryTreeAsync();
        allItems = await MenuSvc.GetItemsAsync();

        foreach (var c in categories)
        {
            var its = allItems.Where(i => i.CategoryId == c.Id).ToList();
            catImages[c.Id] =
                its.FirstOrDefault(i => i.IsRecommended && i.PrimaryImage != null)?.PrimaryImage
                ?? its.FirstOrDefault(i => i.IsPopular && i.PrimaryImage != null)?.PrimaryImage
                ?? its.FirstOrDefault(i => i.PrimaryImage != null)?.PrimaryImage;
        }
    }
}
